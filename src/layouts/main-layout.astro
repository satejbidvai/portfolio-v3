---
import '../styles/global.css';
import '@fontsource-variable/geist';
import Analytics from '@vercel/analytics/astro';
import SiteHeader from '../components/site-header.astro';
import Head from '../components/head.astro';
import type { ComponentProps } from 'astro/types';

interface Props extends ComponentProps<typeof Head> {}
---

<html lang="en">
  <head>
    <Head {...Astro.props} />
    <slot name="head" />
  </head>

  <body class="mx-auto md:max-w-3xl pb-16 md:pb-20 px-6 bg-background text-foreground">
    <main class="mt-8 md:mt-12" transition:animate="fade">
      <SiteHeader />

      <div class="fade-in fade-in-delay-1">
        <slot />
      </div>
    </main>

    <Analytics />

    <script is:inline>
      if (typeof window !== 'undefined' && !window.__sb_greeted) {
        window.__sb_greeted = true;
        console.log(
          "\n\n%cBuilt with Astro, Tailwind, and unreasonable attention to detail <3 %c\n\n%cHiring / Building something cool? Let's chat: satej.bidvai+portfolio@gmail.com",
          'background: #09090b; color: #f9f9f9; font-size: 13px; font-weight: 500; padding: 8px 12px; border-radius: 4px;',
          '',
          'background: #f9f9f9; color: #09090b; font-size: 13px; font-weight: 500; padding: 8px 12px; border-radius: 4px;'
        );
      }
    </script>
  </body>
</html>
